{
  "config": {
    "require-author-tag": true,
    "MD033": {
      "allowed_elements": ["s", "u", "details", "summary"]
    },
    "MD034": false,
    "MD047": false,
    "MD025": false,
    "MD059": false,
  },
  "customRules": [
    "./.vscode/markdownlint-rules/require-author-tag.js"
  ],
  "ignores": [
    "**/bower_components",
    "**/node_modules",
    "**/vendor",
    "**/_*.md",
    "**/index.md"
  ],
  "cSpell.words": [
    "Aiden",
    "Anson",
    "colcon",
    "endraw",
    "Firstname",
    "Huseyin",
    "keybind",
    "Kimmerling",
    "Kutluca",
    "Lastname",
    "Lunabotics",
    "microcontroller",
    "microcontrollers",
    "rosdep",
    "Rviz",
    "Snapcraft",
    "subteam",
    "turtlebot",
    "turtlesim",
    "URDF",
    "Zenoh"
  ]
}